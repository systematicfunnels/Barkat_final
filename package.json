{
  "name": "barkat",
  "version": "1.1.0",
  "description": "Desktop application for housing society maintenance billing, unit management, payments, and reports",
  "main": "./out/main/index.js",
  "author": "Barkat",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:release": "eslint src --rule \"prettier/prettier: off\" --max-warnings 0",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "native:rebuild:node": "npm rebuild better-sqlite3",
    "native:rebuild:electron": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "prebuild": "npm run native:rebuild:electron",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test:core": "jest",
    "test": "node scripts/run-runtime-task.cjs node test:core",
    "test:watch": "jest --watch",
    "test:coverage:core": "jest --coverage",
    "test:coverage": "node scripts/run-runtime-task.cjs node test:coverage:core",
    "test:smoke:core": "jest src/__tests__/integration/production-smoke.integration.test.ts --runInBand",
    "test:smoke": "node scripts/run-runtime-task.cjs node test:smoke:core",
    "test:workerPool:core": "jest src/__tests__/main/utils/workerPool.test.ts",
    "test:workerPool": "node scripts/run-runtime-task.cjs node test:workerPool:core",
    "test:e2e:core": "playwright test",
    "test:e2e": "node scripts/run-runtime-task.cjs electron test:e2e:core",
    "test:e2e:ui:core": "playwright test --ui",
    "test:e2e:ui": "node scripts/run-runtime-task.cjs electron test:e2e:ui:core",
    "test:e2e:headed:core": "playwright test --headed",
    "test:e2e:headed": "node scripts/run-runtime-task.cjs electron test:e2e:headed:core",
    "test:e2e:legacy:core": "playwright test tests/e2e/full-journey.spec.ts",
    "test:e2e:legacy": "node scripts/run-runtime-task.cjs electron test:e2e:legacy:core",
    "verify:release": "npm run lint:release && npm run build && npm run test:smoke && npm run test:e2e"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "dayjs": "^1.11.13",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/exceljs": "^0.5.3",
    "@types/qrcode": "^1.5.6",
    "antd": "^6.2.0",
    "better-sqlite3": "^12.6.2",
    "buffer": "^6.0.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.562.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react-router-dom": "^7.12.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^6.0.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cypress": "^13.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.40.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
